# Supabase Configuration
# Get these from: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database Connection (for migrations)
# Get this from: Supabase Dashboard > Project Settings > Database > Connection string > URI
# IMPORTANT: Use "Session pooler" mode (port 6543), not direct connection (port 5432)
DATABASE_URL=postgresql://postgres.your-project:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Frontend Configuration (must be prefixed with VITE_ for Vite to expose to client)
VITE_THUMBNAIL_BASE_URL=https://d73t4oujvpbw9prl.public.blob.vercel-storage.com
